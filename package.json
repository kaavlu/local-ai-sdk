{
  "name": "dyno",
  "private": true,
  "version": "0.0.1",
  "description": "Dyno — SDK-first local-first AI monorepo (control plane = config + telemetry)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.cjs",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:verbose": "npm run typecheck --workspaces --if-present --loglevel verbose",
    "dev:agent": "npm run dev -w @dyno/agent",
    "dev:agent:9000": "cross-env PORT=9000 npm run dev:agent",
    "dev:all:legacy": "concurrently -k -n agent,app -c cyan,magenta \"npm run dev:agent\" \"npm run dev:app\"",
    "dev:control-plane": "npm run dev -w control-plane-api",
    "dev:app": "npm run dev -w demo-electron",
    "dev:runtime-manager": "npm run dev:app",
    "dev:dashboard": "npm run dev -w ./apps/dashboard-web",
    "dev:all": "npm run dev:runtime-manager",
    "demo:start": "node ./scripts/demo-start.mjs",
    "doctor:sdk": "node ./scripts/dyno-doctor.mjs",
    "test:sdk:smoke": "node scripts/sdk-smoke-test.mjs",
    "test:step16": "node scripts/step16-verify.mjs",
    "test:step17": "node scripts/step17-verify.mjs",
    "test:step18": "node scripts/step18-verify.mjs",
    "test:step19": "node scripts/step19-verify.mjs",
    "test:step19:focused": "node scripts/step19-focused-verify.mjs",
    "test:control-plane": "npm run test -w control-plane-api",
    "stop:agent": "node ./packages/agent/scripts/free-dev-port.mjs",
    "stop:app": "node ./scripts/stop-app.mjs",
    "stop:dashboard": "node ./scripts/stop-dashboard.mjs",
    "stop:all": "npm run stop:app && npm run stop:agent",
    "demo:stop": "npm run stop:all",
    "reset:db": "npm run reset -w @dyno/agent",
    "reset:agent": "npm run reset -w @dyno/agent"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
