{
  "name": "local-ai-sdk",
  "private": true,
  "version": "0.0.1",
  "description": "Local-first AI SDK monorepo (prototype scaffolding)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.cjs",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:agent": "npm run dev -w @local-ai/agent",
    "dev:agent:9000": "cross-env PORT=9000 npm run dev:agent",
    "dev:app": "npm run dev -w demo-electron",
    "dev:all": "concurrently -k -n agent,app -c cyan,magenta \"npm run dev:agent\" \"npm run dev:app\"",
    "test:sdk:smoke": "node scripts/sdk-smoke-test.mjs",
    "stop:agent": "node ./packages/agent/scripts/free-dev-port.mjs",
    "stop:app": "node ./scripts/stop-app.mjs",
    "stop:all": "npm run stop:app && npm run stop:agent",
    "reset:db": "npm run reset -w @local-ai/agent",
    "reset:agent": "npm run reset -w @local-ai/agent"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
