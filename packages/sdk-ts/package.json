{
  "name": "@dynosdk/ts",
  "version": "0.0.1",
  "description": "Dyno TypeScript SDK — client for the local runtime; primary app integration surface",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaavlu/local-ai-sdk.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/kaavlu/local-ai-sdk/tree/main/packages/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/kaavlu/local-ai-sdk/issues"
  },
  "keywords": [
    "dyno",
    "local-first",
    "ai",
    "sdk",
    "typescript",
    "on-device"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "demo": [
        "./dist/demo.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./demo": {
      "types": "./dist/demo.d.ts",
      "require": "./dist/demo.js",
      "default": "./dist/demo.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  }
}
