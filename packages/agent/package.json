{
  "name": "@dyno/agent",
  "version": "0.0.1",
  "description": "Dyno local runtime: HTTP agent API, on-device execution, SQLite persistence",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && node ./scripts/free-dev-port.mjs && node dist/index.js",
    "start": "node dist/index.js",
    "reset": "node ./scripts/reset-agent.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.7.3"
  }
}
